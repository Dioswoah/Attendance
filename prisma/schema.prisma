generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  name                String?
  email               String              @unique
  password            String?
  image               String?
  departmentId        String?
  teamId              String?
  managerId           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  forceLogoutAt       DateTime?
  emailVerified       DateTime?
  roles               Role[]              @default([USER])
  isArchived          Boolean             @default(false)
  deletedAt           DateTime?
  availabilityStatus  UserStatus          @default(AVAILABLE)
  employmentLocation  String?             @map("location")
  customStatusMessage String?
  selectedTimezone    String?             @default("UTC")
  useCurrentTimezone  Boolean             @default(true)
  shiftStartTime      String?             @default("09:00")
  shiftEndTime        String?             @default("17:00")
  managerNotificationsEnabled Boolean     @default(true)
  accounts            Account[]
  attendance                    Attendance[]
  attendanceRequests            AttendanceRequest[]             @relation("AttendanceRequestUser")
  assignedAttendanceRequests    AttendanceRequest[]             @relation("AttendanceRequestAssignedManager")
  chatSessions                  ChatSession[]
  managedDepartments            Department[]                    @relation("DepartmentManager")
  leaves                        Leave[]
  leaveRequests                 LeaveRequest[]                  @relation("LeaveRequestUser")
  assignedLeaveRequests         LeaveRequest[]                  @relation("LeaveRequestAssignedManager")
  notifications       Notification[]
  sessions            Session[]
  ledTeams            Team[]              @relation("TeamLeader")
  workHoursChanges    WorkHoursChangeLog[]
  department          Department?         @relation(fields: [departmentId], references: [id])
  manager             User?               @relation("UserManager", fields: [managerId], references: [id])
  managedUsers        User[]              @relation("UserManager")
  team                Team?               @relation(fields: [teamId], references: [id])
  attendanceSummaries  AttendanceSummary[]
  activityLogs         ActivityLog[]
  overriddenSummaries  AttendanceSummary[] @relation("OverrideManager")
  secondaryDepartments Department[]        @relation("UserSecondaryDepartments")
  leaveHistoryActed    LeaveRequestHistory[] @relation("LeaveHistoryActor")
  @@index([departmentId])
  @@index([teamId])
  @@index([managerId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String    @unique
  userId       String
  expires      DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  createdAt  DateTime @default(now())

  @@id([identifier, token])
}

model Department {
  id             String    @id @default(cuid())
  name           String    @unique
  managerId      String?
  shiftStartTime String?   @default("09:00")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  manager        User?     @relation("DepartmentManager", fields: [managerId], references: [id])
  teams          Team[]
  users          User[]
  secondaryUsers User[]    @relation("UserSecondaryDepartments")
  @@index([managerId])
}

model Team {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  leaderId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  department   Department @relation(fields: [departmentId], references: [id])
  leader       User?      @relation("TeamLeader", fields: [leaderId], references: [id])
  users        User[]
  @@index([departmentId])
  @@index([leaderId])
}

model Attendance {
  id         String           @id @default(cuid())
  userId     String
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  status     AttendanceStatus @default(ABSENT)
  mode       WorkMode         @default(OFFICE)
  locationDetails String?
  duration   Int?
  notes      String?
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  summaryId      String?
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary        AttendanceSummary? @relation(fields: [summaryId], references: [id])
  breaks         Break[]
  breakWarningSent       Boolean   @default(false)
  breakLimitExceededSent Boolean   @default(false)
  overdueDepartureSent   Boolean   @default(false)

  @@index([userId, date])
  @@index([summaryId])
  @@index([clockOut])
}

model Leave {
  id             String    @id @default(cuid())
  userId         String
  startDate      DateTime
  endDate        DateTime
  type           String
  reason         String?
  status         String    @default("APPROVED")
  duration       String
  startTime      DateTime?
  endTime        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  declineReason  String?
  deletedAt      DateTime?
  isArchived     Boolean   @default(false)
  attachmentPath String?   // GCS object path for medical certificate
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, startDate, endDate])
  @@index([status])
}

model LeaveRequest {
  id                String    @id @default(cuid())
  userId            String
  startDate         DateTime
  endDate           DateTime
  type              String
  reason            String?
  status            String    @default("PENDING")
  duration          String
  startTime         DateTime?
  endTime           DateTime?
  declineReason     String?
  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  attachmentPath    String?
  assignedManagerId String?   // Override: routes this request to a specific reviewer instead of user.managerId
  user              User      @relation("LeaveRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedManager   User?     @relation("LeaveRequestAssignedManager", fields: [assignedManagerId], references: [id])
  history           LeaveRequestHistory[]
  @@index([userId, status])
  @@index([startTime, endTime])
  @@index([assignedManagerId])
}

model LeaveRequestHistory {
  id             String       @id @default(cuid())
  leaveRequestId String
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  activity       String
  description    String
  actorId        String?
  actor          User?        @relation("LeaveHistoryActor", fields: [actorId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([leaveRequestId])
}

model Break {
  id           String     @id @default(cuid())
  attendanceId String
  startTime    DateTime
  endTime      DateTime?
  expectedReturnTime DateTime?
  breakExpectedReturnEmailSent Boolean @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  @@index([attendanceId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean   @default(false)
  link      String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  updatedAt DateTime  @default(now()) @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SystemSettings {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model AttendanceRequest {
  id                String    @id @default(cuid())
  userId            String
  date              DateTime
  type              String
  time              DateTime
  reason            String?
  status            String    @default("PENDING")
  declineReason     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  isArchived        Boolean   @default(false)
  targetId          String?
  assignedManagerId String?   // Override: routes this request to a specific reviewer instead of user.managerId
  user              User      @relation("AttendanceRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedManager   User?     @relation("AttendanceRequestAssignedManager", fields: [assignedManagerId], references: [id])
  @@index([userId, status])
  @@index([date])
  @@index([assignedManagerId])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?       @default("New Chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
  USER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum WorkMode {
  OFFICE
  WFH
  ONSITE
  OTHER
}

enum UserStatus {
  AVAILABLE
  BUSY
  DO_NOT_DISTURB
  BE_RIGHT_BACK
  APPEAR_AWAY
  APPEAR_OFFLINE
}

model WorkHoursChangeLog {
  id              String   @id @default(cuid())
  userId          String
  attendanceId    String?
  date            DateTime
  oldStart        String?
  oldEnd          String?
  newStart        String
  newEnd          String
  reason          String?
  changedAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([attendanceId])
}

model AttendanceSummary {
  id                String           @id @default(cuid())
  userId            String
  date              DateTime
  clockIn           DateTime?
  clockOut          DateTime?
  totalWorkDuration Int              @default(0)
  totalBreakDuration Int             @default(0)
  status            AttendanceStatus @default(ABSENT)
  mode              WorkMode         @default(OFFICE)
  
  // Manual Overrides
  isManualOverride  Boolean          @default(false)
  overriddenById    String?
  overrideReason    String?
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  overriddenBy      User?            @relation("OverrideManager", fields: [overriddenById], references: [id])
  rawRecords        Attendance[]

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String?
  entityId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action])
}
