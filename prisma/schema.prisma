generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id @default(cuid())
  name               String?
  email              String         @unique
  password           String?
  image              String?
  departmentId       String?
  teamId             String?
  managerId          String?
  location           String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?
  emailVerified      DateTime?
  roles              Role[]         @default([USER])
  isArchived         Boolean        @default(false)
  accounts           Account[]
  attendance         Attendance[]
  managedDepartments Department[]   @relation("DepartmentManager")
  leaves             Leave[]
  notifications      Notification[]
  attendanceRequests AttendanceRequest[]
  leaveRequests      LeaveRequest[]
  sessions           Session[]
  ledTeams           Team[]         @relation("TeamLeader")
  department         Department?    @relation(fields: [departmentId], references: [id])
  manager            User?          @relation("UserManager", fields: [managerId], references: [id])
  managedUsers       User[]         @relation("UserManager")
  team               Team?          @relation(fields: [teamId], references: [id])
  chatSessions       ChatSession[]
  availabilityStatus UserStatus    @default(AVAILABLE)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  createdAt  DateTime @default(now())

  @@id([identifier, token])
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  managerId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  manager   User?    @relation("DepartmentManager", fields: [managerId], references: [id])
  teams     Team[]
  users     User[]
}

model Team {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  leaderId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  department   Department @relation(fields: [departmentId], references: [id])
  leader       User?      @relation("TeamLeader", fields: [leaderId], references: [id])
  users        User[]
}

model Attendance {
  id         String           @id @default(cuid())
  userId     String
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  status     AttendanceStatus @default(ABSENT)
  mode       WorkMode         @default(OFFICE)
  duration   Int?
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  breaks     Break[]

  @@index([userId, date])
}

model Leave {
  id            String    @id @default(cuid())
  userId        String
  startDate     DateTime
  endDate       DateTime
  type          String
  reason        String?
  status        String    @default("APPROVED") // Changed default to APPROVED since requests handle pending
  duration      String
  startTime     DateTime?
  endTime       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  declineReason String?
  isArchived    Boolean   @default(false)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id            String    @id @default(cuid())
  userId        String
  startDate     DateTime
  endDate       DateTime
  type          String
  reason        String?
  status        String    @default("PENDING")
  duration      String
  startTime     DateTime?
  endTime       DateTime?
  declineReason String?
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Break {
  id           String     @id @default(cuid())
  attendanceId String
  startTime    DateTime
  endTime      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  deletedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
}

enum Role {
  ADMIN
  MANAGER
  USER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum WorkMode {
  OFFICE
  WFH
  OTHER
}

model AttendanceRequest {
  id            String    @id @default(cuid())
  userId        String
  date          DateTime
  type          String    // CLOCK_IN, CLOCK_OUT, BREAK_START, BREAK_END
  time          DateTime
  reason        String?
  status        String    @default("PENDING") // PENDING, APPROVED, DECLINED
  declineReason String?
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?       @default("New Chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
}

enum UserStatus {
  AVAILABLE
  BUSY
  DO_NOT_DISTURB
  BE_RIGHT_BACK
  APPEAR_AWAY
  APPEAR_OFFLINE
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String // "user" or "model"
  content   String      
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
