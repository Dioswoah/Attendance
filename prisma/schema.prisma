generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  name                String?
  email               String              @unique
  password            String?
  image               String?
  departmentId        String?
  teamId              String?
  managerId           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  emailVerified       DateTime?
  roles               Role[]              @default([USER])
  isArchived          Boolean             @default(false)
  deletedAt           DateTime?
  availabilityStatus  UserStatus          @default(AVAILABLE)
  location            String?
  customStatusMessage String?
  selectedTimezone    String?             @default("UTC")
  useCurrentTimezone  Boolean             @default(true)
  accounts            Account[]
  attendance          Attendance[]
  attendanceRequests  AttendanceRequest[]
  chatSessions        ChatSession[]
  managedDepartments  Department[]        @relation("DepartmentManager")
  leaves              Leave[]
  leaveRequests       LeaveRequest[]
  notifications       Notification[]
  sessions            Session[]
  ledTeams            Team[]              @relation("TeamLeader")
  department          Department?         @relation(fields: [departmentId], references: [id])
  manager             User?               @relation("UserManager", fields: [managerId], references: [id])
  managedUsers        User[]              @relation("UserManager")
  team                Team?               @relation(fields: [teamId], references: [id])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String    @unique
  userId       String
  expires      DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  createdAt  DateTime @default(now())

  @@id([identifier, token])
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  managerId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  manager   User?     @relation("DepartmentManager", fields: [managerId], references: [id])
  teams     Team[]
  users     User[]
}

model Team {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  leaderId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  department   Department @relation(fields: [departmentId], references: [id])
  leader       User?      @relation("TeamLeader", fields: [leaderId], references: [id])
  users        User[]
}

model Attendance {
  id         String           @id @default(cuid())
  userId     String
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  status     AttendanceStatus @default(ABSENT)
  mode       WorkMode         @default(OFFICE)
  duration   Int?
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  deletedAt  DateTime?
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  breaks     Break[]

  @@index([userId, date])
}

model Leave {
  id            String    @id @default(cuid())
  userId        String
  startDate     DateTime
  endDate       DateTime
  type          String
  reason        String?
  status        String    @default("APPROVED")
  duration      String
  startTime     DateTime?
  endTime       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  declineReason String?
  deletedAt     DateTime?
  isArchived    Boolean   @default(false)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id            String    @id @default(cuid())
  userId        String
  startDate     DateTime
  endDate       DateTime
  type          String
  reason        String?
  status        String    @default("PENDING")
  duration      String
  startTime     DateTime?
  endTime       DateTime?
  declineReason String?
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Break {
  id           String     @id @default(cuid())
  attendanceId String
  startTime    DateTime
  endTime      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean   @default(false)
  link      String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  updatedAt DateTime  @default(now()) @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model AttendanceRequest {
  id            String    @id @default(cuid())
  userId        String
  date          DateTime
  type          String
  time          DateTime
  reason        String?
  status        String    @default("PENDING")
  declineReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  isArchived    Boolean   @default(false)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String?       @default("New Chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  MANAGER
  USER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum WorkMode {
  OFFICE
  WFH
  OTHER
}

enum UserStatus {
  AVAILABLE
  BUSY
  DO_NOT_DISTURB
  BE_RIGHT_BACK
  APPEAR_AWAY
  APPEAR_OFFLINE
}
